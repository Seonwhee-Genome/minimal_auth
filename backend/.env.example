# Backend runtime env example (loaded by docker-compose via `env_file`)
#
# Used by:
# - `backend/Dockerfile` (Gunicorn bind/workers/timeout via env vars)
# - `backend/auth_server/auth_server/settings.py` (DB + Django config)

# MySQL
MYSQL_DATABASE=auth_db
MYSQL_ROOT_PASSWORD=password
MYSQL_PORT=3306
MYSQL_HOST=host.docker.internal
# Optional: if you add MYSQL_USER support later
# MYSQL_USER=root

# Django / Security
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True

# Gunicorn (runtime)
WEB_BIND=0.0.0.0:8080
WEB_WORKERS=3
WEB_TIMEOUT=120

