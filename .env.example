#
# This is a Docker Compose environment file (loaded automatically by `docker compose`).
#
# Note that backend Django settings currently have DB credentials and host hardcoded in
# `backend/auth_server/auth_server/settings.py`. 
# Keep these defaults in sync with those hardcoded values.
# Rename this filename as .env before you run docker-compose up --build

# MySQL
MYSQL_DATABASE=auth_db
MYSQL_ROOT_PASSWORD=password
MYSQL_PORT=3306

# Django (gunicorn)
WEB_BIND=0.0.0.0:8080
WEB_BIND_PORT=8080
WEB_WORKERS=3
WEB_TIMEOUT=120